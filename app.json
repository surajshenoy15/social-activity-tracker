{
  "expo": {
    "name": "LoRa Connect",
    "slug": "social-activity-tracker",
    "icon": "./assets/images/app-icon.png",
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "2b0107b9-4724-40e9-b07d-76cc0486560b"
      }
    },
    "android": {
      "package": "com.surajshenoy15.socialactivitytracker",
      "permissions": [
        "INTERNET",
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#ffffff"
      }
    }
  }
}